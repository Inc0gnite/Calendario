# ─────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────
# Obtener en: https://supabase.com/dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=***
NEXT_PUBLIC_SUPABASE_ANON_KEY=**

# Solo se usa en Edge Functions / server-side (NO exponer en frontend)
SUPABASE_SERVICE_ROLE_KEY=***

# ─────────────────────────────────────────────
# TWILIO (WhatsApp)
# ─────────────────────────────────────────────
# Obtener en: https://console.twilio.com

TWILIO_ACCOUNT_SID=***
TWILIO_AUTH_TOKEN=***
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Número sandbox de Twilio

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# FERIADOS CHILE
# ─────────────────────────────────────────────
# API pública, no requiere key
NEXT_PUBLIC_HOLIDAYS_API=https://api.boostr.cl/holidays.json
